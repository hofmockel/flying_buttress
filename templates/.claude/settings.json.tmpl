{
  "_comment": "{{project_name}} — scaffolded from flying_buttress on {{date}}. Owner: lead dev. See docs/adr/ for governance.",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(make*)",
      "Read(**)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Read(.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/on_write_fmt.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/on_write_lint.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/on_write_test.py"
          }
        ]
      }
    ]
  }
}
