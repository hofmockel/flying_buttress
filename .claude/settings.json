{
  "_comment": "Owner: senior dev. Changes require senior approval before merge. See docs/adr/ADR-006-settings-governance.md",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(make*)",
      "Read(**)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Read(.env*)",
      "Read(.claude/settings.local.json)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/update_docs_on_commit.py 2>/dev/null || true",
            "if": "Bash(git commit*)",
            "statusMessage": "Updating docs..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python .claude/hooks/index-refresh.py"
          },
          {
            "type": "command",
            "command": ".venv/bin/python .claude/hooks/tool-registry.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/on_write_fmt.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/on_write_lint.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/on_write_test.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python .claude/hooks/bash-logger.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python .claude/hooks/pattern-analyzer.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python .claude/hooks/search-first.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/mcp_check.py"
          }
        ]
      }
    ]
  }
}
