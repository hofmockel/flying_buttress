{
  "_comment": "Owner: senior dev. Changes require senior approval before merge. See docs/adr/ADR-006-settings-governance.md",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(make*)",
      "Read(**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/update_docs_on_commit.py 2>/dev/null || true",
            "if": "Bash(git commit*)",
            "statusMessage": "Updating docs..."
          }
        ]
      }
    ]
  }
}
